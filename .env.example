# ======================================================================
# 配置文件模板
# ----------------------------------------------------------------------
# 使用方法:把这个文件复制一份、改名为  .env  (注意前面有个点),
# 然后在等号右边填上你的密钥。.env 文件里的内容会被后台自动读取。
#
# ⚠️ .env 里有你的真实密钥,绝对不要上传到 GitHub 或发给别人。
# ======================================================================

# —— 核心功能必填 ——
# DeepSeek 大模型密钥。没有它,差评分析和文案生成都没法工作。
# 去 https://platform.deepseek.com 注册后,在 API Keys 页面创建一个。
DEEPSEEK_API_KEY=

# —— 下面是 Stripe 支付相关 ——
# 第一次本地跑通"核心功能"时,这几项可以先留空,后台照样能启动。
# 等你要测试支付环节时,再用 Stripe 测试模式的密钥填进来。
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# —— 一般保持默认即可 ——
# 前端网页地址(支付完成后跳回这里)。本地测试用这个默认值就行。
FRONTEND_URL=http://localhost:5500

# 非会员免费使用"差评分析"的次数
FREE_LIMIT=3
